# Copy this file to `.env.local` and fill in real values for local dev.
# In deployed environments, set these in the Vercel project dashboard.

# Kit (formerly ConvertKit) V3 API — powers the home-page waitlist form.
KIT_API_KEY=your_kit_v3_api_key
KIT_FORM_ID=your_kit_form_id

# Resend — powers the contact form (notification + user confirmation).
RESEND_API_KEY=your_resend_api_key

# Environment marker. Vercel sets VERCEL_ENV automatically in deploys;
# NEXT_PUBLIC_ENV is available if the client bundle needs to know the
# environment (currently unused).
NEXT_PUBLIC_ENV=development
